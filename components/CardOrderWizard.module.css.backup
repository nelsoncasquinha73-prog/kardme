/* ... resto do CSS anterior ... */

.uploadArea {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 120px;
  border: 2px dashed #93c5fd;
  border-radius: 10px;
  padding: 18px;
  text-align: center;
  background: #f8fafc;
  cursor: pointer;
}

.fileInput {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  cursor: pointer;
  z-index: 10;
}

.fileInput:disabled {
  cursor: not-allowed;
}
